{
  "name": "mascot-popup",
  "version": "1.1.1",
  "description": "Desktop mascot popup scheduler",
  "author": "Yamaha Motor Solutions India",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.ymsli.mascot-popup",
    "productName": "sparkY",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "msi",
      "icon": "assets/tray-icon.png"
    },
    "msi": {
      "oneClick": true,
      "runAfterFinish": true,
      "upgradeCode": "6f2a8b6e-6c5b-4a3d-9c2e-2f5a7b1d9e10"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "renderer/**",
      "assets/**",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "node-cron": "^4.6.0",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  }
}
